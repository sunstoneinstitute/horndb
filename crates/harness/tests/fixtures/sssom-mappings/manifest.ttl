@prefix mf:  <http://www.w3.org/2001/sw/DataAccess/tests/test-manifest#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .

<#manifest> a mf:Manifest ;
    mf:entries (
        <#sssom-rg1-exact>
        <#sssom-rg2-broad>
        <#sssom-ri-narrow-broad>
        <#sssom-rce1-broad>
        <#sssom-t1-broad>
        <#sssom-neg-exact>
        <#sssom-biomappings-slice>
    ) .

<#sssom-rg1-exact> a mf:PositiveEntailmentTest ;
    mf:name "SSSOM RG1: owl:equivalentClass generalises to skos:exactMatch" ;
    mf:action <rg1-exact-premise.ttl> ;
    mf:result <rg1-exact-conclusion.ttl> .

<#sssom-rg2-broad> a mf:PositiveEntailmentTest ;
    mf:name "SSSOM RG2: rdfs:subClassOf generalises to skos:broadMatch" ;
    mf:action <rg2-broad-premise.ttl> ;
    mf:result <rg2-broad-conclusion.ttl> .

<#sssom-ri-narrow-broad> a mf:PositiveEntailmentTest ;
    mf:name "SSSOM RI1/2: skos:narrowMatch inverts to skos:broadMatch" ;
    mf:action <ri-narrow-broad-premise.ttl> ;
    mf:result <ri-narrow-broad-conclusion.ttl> .

<#sssom-rce1-broad> a mf:PositiveEntailmentTest ;
    mf:name "SSSOM RCE1: skos:exactMatch o skos:broadMatch => skos:broadMatch" ;
    mf:action <rce1-broad-premise.ttl> ;
    mf:result <rce1-broad-conclusion.ttl> .

<#sssom-t1-broad> a mf:PositiveEntailmentTest ;
    mf:name "SSSOM T1: skos:broadMatch transitivity" ;
    mf:action <t1-broad-premise.ttl> ;
    mf:result <t1-broad-conclusion.ttl> .

<#sssom-neg-exact> a mf:PositiveEntailmentTest ;
    mf:name "SSSOM F4: skos:exactMatch o horndb:notExactMatch => horndb:notExactMatch" ;
    mf:action <neg-exact-premise.ttl> ;
    mf:result <neg-exact-conclusion.ttl> .

<#sssom-biomappings-slice> a mf:PositiveEntailmentTest ;
    mf:name "SSSOM F9: real Biomappings slice loads and chains via T1-exact transitivity" ;
    mf:action <biomappings-slice.sssom.tsv> ;
    mf:result <biomappings-slice-conclusion.ttl> .
